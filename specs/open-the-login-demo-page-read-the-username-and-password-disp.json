{
  "mode": "pytest",
  "url": "https://testtrack.org/login-demo",
  "browser": "chrome",
  "headless": false,
  "test_scenarios": [
    {
      "id": "TC001",
      "name": "Successful login with authorized credentials",
      "description": "Tests logging in using the credentials provided in the AUTHORIZED CREDENTIALS section.",
      "steps": [
        "open LoginPage.URL",
        "read the username and password from AUTHORIZED CREDENTIALS section",
        "type username into Enter your username on LoginPage",
        "type password into Enter your password on LoginPage",
        "click INITIATE LOGIN SEQUENCE on LoginPage",
        "wait_for_url('/dashboard')"
      ],
      "expected_result": "User is successfully logged in and redirected to the dashboard page.",
      "test_data": {
        "username": "testuser",
        "password": "password123"
      }
    }
  ],
  "page_objects_needed": [
    "LoginPage"
  ],
  "locators": [
    {
      "page_object": "LoginPage",
      "element": "username field",
      "css": "#username",
      "xpath": "//input[@id='username']",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "LoginPage",
      "element": "password field",
      "css": "#password",
      "xpath": "//input[@id='password']",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "LoginPage",
      "element": "initiate login button",
      "css": "#login-submit",
      "xpath": "//button[@id='login-submit']",
      "preferred": "css",
      "wait_condition": "clickable"
    },
    {
      "page_object": "LoginPage",
      "element": "authorized username display",
      "css": "",
      "xpath": "//p[contains(normalize-space(), 'USERNAME:')]",
      "preferred": "xpath",
      "wait_condition": "visible"
    },
    {
      "page_object": "LoginPage",
      "element": "authorized password display",
      "css": "",
      "xpath": "//p[contains(normalize-space(), 'PASSWORD:')]",
      "preferred": "xpath",
      "wait_condition": "visible"
    }
  ],
  "pytest_markers": [
    "smoke"
  ],
  "notes": ""
}