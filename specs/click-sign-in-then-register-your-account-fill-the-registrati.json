{
  "mode": "pytest",
  "url": "https://practicesoftwaretesting.com",
  "browser": "chrome",
  "headless": false,
  "test_scenarios": [
    {
      "id": "TC001",
      "name": "Register new account",
      "description": "Registers a new account with random data and verifies account creation.",
      "steps": [
        "open LoginPage.URL",
        "click [Sign in] on HomePage",
        "click [Register your account] on LoginPage",
        "wait_for_url('auth/register')",
        "type [First name *] on RegisterPage",
        "type [Your last name *] on RegisterPage",
        "type [YYYY-MM-DD] on RegisterPage",
        "select [Your country *] on RegisterPage",
        "type [Your Postcode *] on RegisterPage",
        "type [e.g. 42 *] on RegisterPage",
        "type [Your Street *] on RegisterPage",
        "type [Your City *] on RegisterPage",
        "type [Your State *] on RegisterPage",
        "type [Your phone *] on RegisterPage",
        "type [Your email *] on RegisterPage",
        "type [Your password] on RegisterPage",
        "click [Register] on RegisterPage",
        "wait_for_url('welcome')"
      ],
      "expected_result": "User should see a welcome message confirming account creation.",
      "test_data": {
        "first_name": "John",
        "last_name": "Doe",
        "dob": "1990-01-01",
        "country": "Albania",
        "postcode": "12345",
        "house_number": "42",
        "street": "Main Street",
        "city": "Tirana",
        "state": "Tirana",
        "phone": "+355692345678",
        "email": "GENERATE_UNIQUE_AT_RUNTIME",
        "password": "Str0ngPa$$w0rd"
      }
    }
  ],
  "page_objects_needed": [
    "HomePage",
    "LoginPage",
    "RegisterPage"
  ],
  "locators": [
    {
      "page_object": "HomePage",
      "element": "Sign in",
      "css": "[data-test=\"nav-sign-in\"]",
      "xpath": "//a[@data-test=\"nav-sign-in\"]",
      "preferred": "css",
      "wait_condition": "clickable"
    },
    {
      "page_object": "LoginPage",
      "element": "Register your account",
      "css": "[data-test=\"register-link\"]",
      "xpath": "//a[@data-test=\"register-link\"]",
      "preferred": "css",
      "wait_condition": "clickable"
    },
    {
      "page_object": "RegisterPage",
      "element": "First name",
      "css": "[data-test=\"first-name\"]",
      "xpath": "//input[@data-test=\"first-name\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Last name",
      "css": "[data-test=\"last-name\"]",
      "xpath": "//input[@data-test=\"last-name\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Date of Birth",
      "css": "[data-test=\"dob\"]",
      "xpath": "//input[@data-test=\"dob\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Country",
      "css": "[data-test=\"country\"]",
      "xpath": "//select[@data-test=\"country\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Postal code",
      "css": "[data-test=\"postal_code\"]",
      "xpath": "//input[@data-test=\"postal_code\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "House number",
      "css": "[data-test=\"house_number\"]",
      "xpath": "//input[@data-test=\"house_number\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Street",
      "css": "[data-test=\"street\"]",
      "xpath": "//input[@data-test=\"street\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "City",
      "css": "[data-test=\"city\"]",
      "xpath": "//input[@data-test=\"city\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "State",
      "css": "[data-test=\"state\"]",
      "xpath": "//input[@data-test=\"state\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Phone",
      "css": "[data-test=\"phone\"]",
      "xpath": "//input[@data-test=\"phone\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Email",
      "css": "[data-test=\"email\"]",
      "xpath": "//input[@data-test=\"email\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Password",
      "css": "[data-test=\"password\"]",
      "xpath": "//input[@data-test=\"password\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Register Button",
      "css": "[data-test=\"register-submit\"]",
      "xpath": "//button[@data-test=\"register-submit\"]",
      "preferred": "css",
      "wait_condition": "clickable"
    }
  ],
  "pytest_markers": [
    "smoke"
  ],
  "notes": "Ensure unique email generation at runtime to prevent collision."
}