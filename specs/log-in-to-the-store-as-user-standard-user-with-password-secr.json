{
  "mode": "pytest",
  "url": "https://www.saucedemo.com",
  "browser": "chrome",
  "headless": false,
  "test_scenarios": [
    {
      "id": "TC001",
      "name": "Login with valid standard_user credentials redirects to Inventory page",
      "description": "Verifies that a valid login with standard_user/secret_sauce navigates to the inventory page.",
      "steps": [
        "open LoginPage.URL",
        "type Username on LoginPage",
        "type Password on LoginPage",
        "click Login on LoginPage",
        "wait_for_url('/inventory.html')",
        "interact with InventoryPage"
      ],
      "expected_result": "User is authenticated and redirected to the inventory page; current URL contains '/inventory.html'.",
      "test_data": {
        "username": "standard_user",
        "password": "secret_sauce"
      }
    }
  ],
  "page_objects_needed": [
    "LoginPage",
    "InventoryPage"
  ],
  "locators": [
    {
      "page_object": "LoginPage",
      "element": "Username",
      "css": "[data-test=\"username\"]",
      "xpath": "//input[@data-test=\"username\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "LoginPage",
      "element": "Password",
      "css": "[data-test=\"password\"]",
      "xpath": "//input[@data-test=\"password\"]",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "LoginPage",
      "element": "Login",
      "css": "[data-test=\"login-button\"]",
      "xpath": "//input[@data-test=\"login-button\"]",
      "preferred": "css",
      "wait_condition": "clickable"
    }
  ],
  "pytest_markers": [
    "smoke"
  ],
  "notes": "Multi-page flow uses separate page objects (LoginPage \u2192 InventoryPage). Only scanned DOM locators used. After clicking Login, wait_for_url('/inventory.html') is required. Use safe_type for inputs on SPA/React forms."
}