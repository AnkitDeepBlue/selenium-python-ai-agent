{
  "mode": "pytest",
  "url": "https://sauce-demo.myshopify.com",
  "browser": "chrome",
  "headless": false,
  "test_scenarios": [
    {
      "id": "TC001",
      "name": "Create Account and Verify Success",
      "description": "This test verifies that a user can create an account successfully and logout.",
      "steps": [
        "open HomePage.URL",
        "click 'Sign up' on HomePage",
        "wait_for_url('/account/register')",
        "safe_type 'first_name' on RegisterPage with random first name",
        "safe_type 'last_name' on RegisterPage with random last name",
        "safe_type 'email' on RegisterPage with unique random email",
        "safe_type 'password' on RegisterPage with random password",
        "click 'Create' on RegisterPage",
        "wait_for_url('/account')",
        "verify account creation success message is visible",
        "click 'Log Out' on AccountPage",
        "wait_for_url('/account/login')"
      ],
      "expected_result": "Account is created successfully and user is redirected to the login page.",
      "test_data": {
        "first_name": "GENERATE_UNIQUE_AT_RUNTIME",
        "last_name": "GENERATE_UNIQUE_AT_RUNTIME",
        "email": "GENERATE_UNIQUE_AT_RUNTIME",
        "password": "GENERATE_UNIQUE_AT_RUNTIME"
      }
    }
  ],
  "page_objects_needed": [
    "HomePage",
    "RegisterPage",
    "AccountPage"
  ],
  "locators": [
    {
      "page_object": "HomePage",
      "element": "Sign up link",
      "xpath": "//a[@id='customer_register_link']",
      "preferred": "xpath",
      "wait_condition": "clickable"
    },
    {
      "page_object": "RegisterPage",
      "element": "first_name",
      "css": "#first_name #first_name",
      "xpath": "//input[@id='first_name']",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "last_name",
      "css": "#last_name #last_name",
      "xpath": "//input[@id='last_name']",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "email",
      "css": "#email #email",
      "xpath": "//input[@id='email']",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "password",
      "css": "#password #password",
      "xpath": "//input[@id='password']",
      "preferred": "css",
      "wait_condition": "visible"
    },
    {
      "page_object": "RegisterPage",
      "element": "Create button",
      "css": "#create_customer input[type='submit']",
      "xpath": "//*[@id='create_customer']//input[@type='submit']",
      "preferred": "css",
      "wait_condition": "clickable"
    },
    {
      "page_object": "AccountPage",
      "element": "Log Out",
      "xpath": "//a[@id='customer_logout_link']",
      "preferred": "xpath",
      "wait_condition": "clickable"
    }
  ],
  "pytest_markers": [
    "smoke"
  ],
  "notes": ""
}